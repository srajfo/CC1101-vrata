esphome:
  name: cc1101
  friendly_name: cc1101

esp32:
  board: esp32-c3-devkitm-1
  framework:
    type: esp-idf

logger:

api:
  services:
    - service: posalji_paket
      variables:
        hex_paket: string
      then:
        - lambda: |-
            ESP_LOGD("cc1101", "Servis pozvan! hex_paket = %s", hex_paket.c_str());
        - cc1101.begin_tx:
        - lambda: |-
            std::string hex = hex_paket;
            std::vector<uint8_t> data;

            hex.erase(std::remove(hex.begin(), hex.end(), ' '), hex.end());

            for (size_t i = 0; i + 1 < hex.size(); i += 2) {
              std::string byte_str = hex.substr(i, 2);
              uint8_t byte = (uint8_t)strtol(byte_str.c_str(), nullptr, 16);
              data.push_back(byte);
            }

            while (data.size() < 8) data.push_back(0x00);
            data.resize(8);

            id(packet_to_send) = data;
            ESP_LOGD("cc1101", "Šaljem paket: %s", format_hex(data).c_str());

        - cc1101.send_packet:
            data: !lambda "return id(packet_to_send);"

        - delay: 10ms
        - cc1101.begin_rx:

