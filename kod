cc1101:
  id: cc1101_radio
  cs_pin: GPIO7
  gdo0_pin: GPIO2
  frequency: 433.92MHz
  modulation_type: GFSK
  symbol_rate: 4800
  packet_mode: true
  packet_length: 8
  on_packet:
    then:
      - lambda: |-
          char hex[256];
          ESP_LOGD("cc1101", "Primljeno: %s | freq_offset %.0f Hz | rssi %.1f dBm | lqi %u",
                   format_hex_to(hex, x), freq_offset, rssi, lqi);
